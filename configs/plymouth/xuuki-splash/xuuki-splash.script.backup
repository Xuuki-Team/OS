# xuuki-splash for Plymouth (correct syntax)
# Use # for comments, not //

# Get screen dimensions
screen_width = Window.GetWidth()
screen_height = Window.GetHeight()

# Load and display background
bg_image = Image("background.png")
bg_sprite = Sprite(bg_image)

# Get image dimensions
bg_width = bg_image.GetWidth()
bg_height = bg_image.GetHeight()

# Calculate scale to fill screen
scale_x = screen_width / bg_width
scale_y = screen_height / bg_height

# Use larger scale
if (scale_y > scale_x)
{
  scale = scale_y
}
else
{
  scale = scale_x
}

# Set background position and scale
bg_sprite.SetScale(scale, scale)
bg_sprite.SetX(Window.GetX() + screen_width / 2 - (bg_width * scale) / 2)
bg_sprite.SetY(Window.GetY() + screen_height / 2 - (bg_height * scale) / 2)
bg_sprite.SetZ(-10)

# Simple animation
phase = 0.0

fun refresh_callback()
{
  phase = phase + 0.02
}

Plymouth.SetRefreshFunction(refresh_callback)

fun boot_progress_callback(duration, progress)
{
  # Minimal callback for progress
}

Plymouth.SetBootProgressFunction(boot_progress_callback)